BOT_TOKEN=

# Proxy settings.
# Leave these empty to connect directly.
# Example values for a local vless-client sidecar:
# ALL_PROXY=socks5://vless-client:1080
ALL_PROXY=socks5://vless-client:1080
DATABASE_PATH=data/bot.sqlite3
CHECK_THROTTLE_SECONDS=30
DEV_MODE=false

# Logging
LOG_LEVEL=INFO
ADMIN_ID=
